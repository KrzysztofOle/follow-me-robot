    {
      "label": "PIO: Build uart_led",
      "type": "shell",
      "command": "~/.platformio/penv/bin/pio",
      "args": ["run", "-e", "uart_led"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "UART LED: Build + Upload + Monitor",
      "dependsOn": [
        "PIO: Build uart_led",
        "PIO: Upload uart_led",
        "PIO: Monitor uart_led"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "PIO: Upload uart_led",
      "type": "shell",
      "command": "~/.platformio/penv/bin/pio",
      "args": ["run", "-e", "uart_led", "-t", "upload"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "PIO: Monitor uart_led",
      "type": "shell",
      "command": "~/.platformio/penv/bin/pio",
      "args": ["device", "monitor", "-b", "115200", "-p", "/dev/tty.usbserial-0001"],
      "problemMatcher": []
    },
