---
import MainLayout from "../layouts/MainLayout.astro";

// Dynamic import README z root repo
const readme = await import("../../../README.md");
const { Content, frontmatter } = readme;
---

<MainLayout title="Dokumentacja">
  <article class="prose prose-slate max-w-3xl mx-auto">
    <h1>{frontmatter?.title ?? "Dokumentacja"}</h1>
    <div class="docs-content bg-gray-50 border rounded-lg p-4 mb-6">
      <Content />
    </div>
  </article>
</MainLayout>
