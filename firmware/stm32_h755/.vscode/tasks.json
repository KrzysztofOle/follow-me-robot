{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PIO: Build H755 CM7",
      "type": "shell",
      "command": "~/.platformio/penv/bin/pio",
      "args": ["run", "-e", "nucleo_h755zi_q_cm7"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "PIO: Upload H755 CM7",
      "type": "shell",
      "command": "~/.platformio/penv/bin/pio",
      "args": ["run", "-e", "nucleo_h755zi_q_cm7", "-t", "upload"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "PIO: Monitor H755 CM7",
      "type": "shell",
      "command": "~/.platformio/penv/bin/pio",
      "args": [
        "device",
        "monitor",
        "-b",
        "115200",
        "-p",
        "/dev/cu.usbmodem24203"
      ],
      "problemMatcher": []
    },
    {
      "label": "H755 CM7: Build + Upload + Monitor",
      "dependsOn": [
        "PIO: Build H755 CM7",
        "PIO: Upload H755 CM7",
        "PIO: Monitor H755 CM7"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "PIO: Build H755 CM4",
